    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "svelte": "^5.55.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^2.1.0"
  },
  "type": "module"
}
