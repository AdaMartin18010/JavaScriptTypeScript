{
  "name": "milestone-04-distributed-tracing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:users\" \"npm run dev:orders\" \"npm run dev:notifications\"",
    "dev:gateway": "tsx watch gateway/src/server.ts",
    "dev:users": "tsx watch services/users/src/server.ts",
    "dev:orders": "tsx watch services/orders/src/server.ts",
    "dev:notifications": "tsx watch services/notifications/src/server.ts",
    "infra": "docker-compose -f ../docker-compose.yml up -d",
    "build": "tsc",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.41.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/resources": "^1.21.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/semantic-conventions": "^1.21.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nats": "^2.19.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
