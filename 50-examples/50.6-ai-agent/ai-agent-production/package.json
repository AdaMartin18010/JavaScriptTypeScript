{
  "name": "ai-agent-production",
  "version": "1.0.0",
  "description": "智能研发团队助手 — 基于 Mastra + Vercel AI SDK v6 + MCP + better-auth + Hono 的多 Agent 协作系统",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "mcp:filesystem": "tsx mcp-servers/filesystem-server/index.ts",
    "mcp:github": "tsx mcp-servers/github-server/index.ts",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/deepseek": "^0.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.4.0",
    "@mastra/core": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@paralleldrive/cuid2": "^2.2.0",
    "ai": "^4.2.0",
    "better-auth": "^1.2.0",
    "better-sqlite3": "^11.9.0",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
