graph LR
    N["新手<br/>Novice<br/>遵循规则"] -->|"模式积累"| A["高级初学者<br/>Advanced Beginner"]
    A -->|"情境判断"| C["胜任者<br/>Competent<br/>目标导向"]
    C -->|"直觉发展"| P["精通者<br/>Proficient<br/>全局视角"]
    P -->|"模式识别"| E["专家<br/>Expert<br/>直觉决策"]
    E -->|"融会贯通"| M["大师<br/>Master<br/>超越规则"]

    N -.->|"TS 错误信息理解<br/>需要显式推理"| N
    E -.->|"TS 错误信息理解<br/>模式匹配，即时反应"| E

    style N fill:#ffebee
