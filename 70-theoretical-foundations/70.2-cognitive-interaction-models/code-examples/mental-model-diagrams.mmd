%% 心智模型与编程语言的多维认知图谱
%% 用于支持 70.2 方向的认知分析
%% @reference Johnson-Laird, Mental Models (1983); Stefik & Hanenberg (2014)

%% ============================================
%% 图 1: 动态类型 vs 静态类型的心智模型映射
%% ============================================
graph LR
    subgraph Dynamic["动态类型心智模型"]
        D1["值携带类型标签<br/>runtime tag check"]
        D2["鸭子类型直觉<br/>'如果它像鸭子...'"]
        D3["运行时惊喜<br/>TypeError at runtime"]
    end

    subgraph Static["静态类型心智模型"]
        S1["变量绑定类型<br/>compile-time check"]
        S2["契约先行直觉<br/>'先签协议再交易'"]
        S3["编译时保证<br/>No runtime type errors"]
    end

    D1 <-->|"认知切换成本<br/>2-4 周"| S1
    D2 <-->|"思维模式冲突<br/>鸭子 → 契约"| S2
    D3 <-->|"错误发现时机<br/>运行 → 编译"| S3

    style Dynamic fill:#fff3e0
    style Static fill:#e3f2fd

%% ============================================
%% 图 2: 前端框架的多模型映射
%% ============================================
graph TB
    subgraph ReactModel["React 心智模型"]
        R1["UI = f(state)"]
        R2["单向数据流"]
        R3["Virtual DOM Diff"]
    end

    subgraph VueModel["Vue 心智模型"]
        V1["响应式代理<br/>Transparent reactivity"]
        V2["双向绑定可选"]
        V3["模板编译 + Patch"]
    end

    subgraph SolidModel["Solid 心智模型"]
        So1["Signal = 细粒度原子"]
        So2["自动依赖追踪"]
        So3["直接 DOM 更新"]
    end

    subgraph SvelteModel["Svelte 心智模型"]
        Sv1["编译时魔法"]
        Sv2["无运行时框架"]
        Sv3["生成更新代码"]
    end

    R1 -.->|"认知距离: 中"| V1
    R1 -.->|"认知距离: 高"| So1
    V1 -.->|"认知距离: 低"| So1
    So1 -.->|"认知距离: 中"| Sv1

    style ReactModel fill:#e3f2fd
    style VueModel fill:#e8f5e9
    style SolidModel fill:#fce4ec
    style SvelteModel fill:#fff3e0

%% ============================================
%% 图 3: 异步模式的认知负荷层级
%% ============================================
graph LR
    CB["回调地狱<br/>Callback Hell"] -->|"认知负荷 ↓"| PC["Promise 链<br/>Promise Chain"]
    PC -->|"认知负荷 ↓"| AA["async/await<br/>Syntactic Sugar"]
    AA -->|"认知负荷 ↓"| RX["RxJS Observable<br/>Stream Algebra"]

    CB -.->|"WM 占用: 7±2 chunks"| CB
    PC -.->|"WM 占用: 5±2 chunks"| PC
    AA -.->|"WM 占用: 3±1 chunks"| AA
    RX -.->|"WM 占用: 6±2 chunks<br/>学习曲线陡峭"| RX

    style CB fill:#ffebee
    style PC fill:#fff3e0
    style AA fill:#e8f5e9
    style RX fill:#e1f5fe

