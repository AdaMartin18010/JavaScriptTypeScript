{
  "compilerOptions": {
    /* 基础配置 */
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler 模式 */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* 严格类型检查 */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* 路径别名 - Monorepo */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@packages/*": ["packages/*"],
      "@myorg/core": ["packages/core/src"],
      "@myorg/core/*": ["packages/core/src/*"],
      "@myorg/utils": ["packages/utils/src"],
      "@myorg/utils/*": ["packages/utils/src/*"],
      "@myorg/ui": ["packages/ui/src"],
      "@myorg/ui/*": ["packages/ui/src/*"],
      "@myorg/hooks": ["packages/hooks/src"],
      "@myorg/hooks/*": ["packages/hooks/src/*"]
    },

    /* 类型定义 */
    "types": ["vite/client", "node", "vitest/globals"]
  },
  "include": [
    "src/**/*",
    "packages/*/src/**/*",
    "packages/*/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/*/dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./packages/core" },
    { "path": "./packages/utils" },
    { "path": "./packages/ui" },
    { "path": "./packages/hooks" }
  ]
}
