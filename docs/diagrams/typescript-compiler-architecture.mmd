```mermaid
%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '15px'}}}%%
flowchart TB
    subgraph Input["📥 输入层 (Input)"]
        TS[TypeScript Source Files<br/>.ts, .tsx, .d.ts]
        Config[tsconfig.json<br/>编译器配置]
        Lib[lib.d.ts<br/>内置类型定义]
    end
    
    subgraph CoreCompiler["🔧 TypeScript Compiler Core"]
        direction TB
        
        subgraph ScannerPhase["1️⃣ Scanner / Lexer<br/>词法分析"]
            Scanner["Scanner<br/>扫描器"]
            ScannerFunc["• scan()
            <br/>• 识别 Token
            <br/>• 处理注释/空白
            <br/>• 位置信息记录"]
        end
        
        Scanner --> Tokens["📄 Token Stream<br/>词法单元流"]
        Tokens --> ParserPhase
        
        subgraph ParserPhase["2️⃣ Parser<br/>语法分析"]
            Parser["Parser<br/>解析器"]
            ParserFunc["• parseSourceFile()
            <br/>• 递归下降解析
            <br/>• 构建 AST
            <br/>• 语法错误检测"]
        end
        
        Parser --> AST["🌳 Abstract Syntax Tree<br/>抽象语法树<br/>SourceFile 对象"]
        AST --> BinderPhase
        
        subgraph BinderPhase["3️⃣ Binder<br/>语义绑定"]
            Binder["Binder<br/>绑定器"]
            BinderFunc["• bindSourceFile()
            <br/>• 创建 Symbol
            <br/>• 作用域分析
            <br/>• 建立符号表"]
        end
        
        Binder --> Symbols["📊 Symbol Table<br/>符号表<br/>{ Symbol → Declaration }"]
        Symbols --> CheckerPhase
        
        subgraph CheckerPhase["4️⃣ Checker<br/>类型检查"]
            Checker["Type Checker<br/>类型检查器"]
            CheckerFunc["• getTypeOfSymbol()
            <br/>• 类型推断
            <br/>• 类型兼容性检查
            <br/>• 泛型实例化
            <br/>• 错误报告"]
        end
        
        Checker --> Types["🎯 Type System<br/>类型系统"]
        Types --> TransformerPhase
        
        subgraph TransformerPhase["5️⃣ Transformer<br/>代码转换"]
            Transformer["Transformer<br/>转换器"]
            TransformerFunc["• 访问者模式遍历 AST
            <br/>• ESNext → 目标版本
            <br/>• JSX 转换
            <br/>• 装饰器转换
            <br/>• 模块解析"]
        end
        
        Transformer --> TransformedAST["🔄 Transformed AST<br/>转换后的 AST"]
        TransformedAST --> EmitterPhase
        
        subgraph EmitterPhase["6️⃣ Emitter<br/>代码生成"]
            Emitter["Emitter<br/>发射器"]
            EmitterFunc["• emitSourceFile()
            <br/>• AST → JavaScript
            <br/>• Source Map 生成
            <br/>• 声明文件(.d.ts)"]
        end
    end
    
    Emitter --> Output["📤 输出层 (Output)"]
    
    subgraph Output["📤 输出层 (Output)"]
        direction TB
        JS["JavaScript Files<br/>.js, .jsx"]
        DTS["Declaration Files<br/>.d.ts"]
        MAP["Source Maps<br/>.js.map"]
        Errors["Diagnostics<br/>错误与警告"]
    end
    
    %% 错误流
    Checker -.->|报告类型错误| Errors
    Parser -.->|报告语法错误| Errors
    Binder -.->|报告作用域错误| Errors
    
    %% 关键组件说明
    subgraph KeyComponents["🔑 关键内部组件"]
        direction TB
        TC[TypeController<br/>类型控制器]
        NR[NodeFactory<br/>节点工厂]
        PR[Printer<br/>代码打印器]
        SM[SourceMapGenerator<br/>SourceMap生成器]
    end
    
    Checker -.-> TC
    Parser -.-> NR
    Emitter -.-> PR
    Emitter -.-> SM
    
