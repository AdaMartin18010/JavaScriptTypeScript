    class ScannerPhase,ParserPhase,BinderPhase,CheckerPhase,TransformerPhase,EmitterPhase phase
    class Tokens,AST,Symbols,Types,TransformedAST data
    class Input,Output,TS,Config,Lib,JS,DTS,MAP,Errors io
    class Scanner,Parser,Binder,Checker,Transformer,Emitter,TC,NR,PR,SM component
    
