# ============================================
# AI Agent Production — 环境变量配置模板
# ============================================

# AI 模型提供商 API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 默认使用的模型（支持 openai, anthropic, deepseek 等）
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# better-auth 安全配置
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# OAuth 提供商配置（可选）
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 数据库配置（SQLite 用于本地开发，生产环境可替换为 PostgreSQL）
DATABASE_URL=file:./database/dev.db

# MCP Server 配置
MCP_FILESYSTEM_ROOT=./data/mcp-files
MCP_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hono 服务器配置
PORT=3000
NODE_ENV=development

# 速率限制配置（请求/分钟）
RATE_LIMIT_PER_MINUTE=60

# Cloudflare Workers 部署配置（可选）
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
