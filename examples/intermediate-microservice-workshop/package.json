{
  "name": "intermediate-microservice-workshop",
  "version": "1.0.0",
  "description": "从零构建 Node.js/TypeScript 微服务系统 —— 中级开发者进阶实战",
  "private": true,
  "scripts": {
    "m1": "cd milestone-01-api-gateway && npm run dev",
