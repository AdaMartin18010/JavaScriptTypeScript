# ============================================
# 环境变量示例文件
# 复制为 .env 后填写实际值
# ============================================

# Expo 项目 ID（用于 EAS 构建服务）
EXPO_PROJECT_ID=your-expo-project-id

# API 基础地址
API_BASE_URL=https://api.example.com/v1

# 应用环境: development | staging | production
NODE_ENV=development

# 是否启用调试日志
DEBUG_ENABLED=true
