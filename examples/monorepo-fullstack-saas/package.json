{
  "name": "monorepo-fullstack-saas",
  "private": true,
  "version": "1.0.0",
  "description": "Fullstack SaaS monorepo template with Next.js + NestJS",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@saas/eslint-config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
