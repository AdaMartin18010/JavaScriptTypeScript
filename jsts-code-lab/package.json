{
  "name": "jsts-code-lab",
  "version": "4.0.0",
  "description": "JavaScript/TypeScript 代码实验室 - 从理论到实践的完整代码示例",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "run:ts": "tsx",
    "playground": "tsx playground/quick-start/index.ts",
    "demo": "tsx run-demos.ts",
    "demo:all": "tsx run-demos.ts",
    "demo:patterns": "tsx run-demos.ts design-patterns",
    "demo:architecture": "tsx run-demos.ts architecture-patterns",
    "demo:comparison": "tsx run-demos.ts js-ts-comparison",
    "benchmark": "tsx 11-benchmarks/js-vs-ts-performance.ts",
    "stats": "node -e \"const fs=require('fs'),path=require('path');function walk(d){let c=0;for(const e of fs.readdirSync(d,{withFileTypes:true})){if(e.isDirectory()&&e.name!=='node_modules'&&e.name!=='dist')c+=walk(path.join(d,e.name));else if(e.isFile()&&e.name.endsWith('.ts'))c++;}return c;}console.log(walk('.'));\""
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.20.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "javascript",
    "typescript",
    "ecmascript",
    "design-patterns",
    "concurrency",
    "semantic-models",
    "compiler-api",
    "type-theory",
    "formal-semantics",
    "examples",
    "tutorial"
  ],
  "license": "MIT",
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
