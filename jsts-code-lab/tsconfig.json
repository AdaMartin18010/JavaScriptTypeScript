{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@core/*": ["00-language-core/*"],
      "@patterns/*": ["02-design-patterns/*"],
      "@concurrency/*": ["03-concurrency/*"]
    }
  },
  "include": ["**/*.ts", "**/*.mts", "**/*.cts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
