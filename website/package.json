{
  "name": "awesome-jsts-ecosystem-docs",
  "version": "4.1.0",
  "description": "Awesome JavaScript/TypeScript Ecosystem 文档站点",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "lint": "oxlint . --ignore-pattern dist --ignore-pattern node_modules",
    "format": "prettier --write \"**/*.{md,ts,js,json}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@stackblitz/sdk": "^1.11.0",
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "prettier": "^3.5.0",
    "vitepress": "^1.6.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.0"
  },
  "keywords": [
    "javascript",
    "typescript",
    "ecosystem",
    "awesome",
    "documentation"
  ],
  "license": "MIT"
}
